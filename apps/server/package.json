{
  "name": "@macrograph/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "build": "pnpm rolldown -c rolldown.config.ts",
    "typecheck": "tsgo --build",
